```python
# SPDX-License-Identifier: Apache-2.0

import json
import logging
import os
from ctypes import byref, windll, wintypes
from typing import Optional

type Response = dict[bool, Optional[str]]

LOG_FILE = os.path.join(
    os.environ.get("USERPROFILE", "."),
    "python_plugin.log"
)

logging.basicConfig(
    filename=LOG_FILE,
    level=logging.INFO,
    format="%(asctime)s - %(levelname)s - %(message)s"
)

# =========================
# 中文 → 英文 指令映射表
# =========================
COMMAND_MAP = {
    "初始化": "initialize",
    "啟動": "initialize",
    "關閉": "shutdown",
    "停止": "shutdown",
    "重啟": "restart",
    "狀態": "status",
    "幫助": "help"
}

# =========================
# 主程式
# =========================
def main():
    TOOL_CALLS_PROPERTY = "tool_calls"
    FUNCTION_PROPERTY = "func"
    PARAMS_PROPERTY = "properties"
    CONTEXT_PROPERTY = "messages"
    SYSTEM_INFO_PROPERTY = "system_info"

    INITIALIZE_COMMAND = "initialize"
    SHUTDOWN_COMMAND = "shutdown"

    commands = {
        "initialize": execute_initialize_command,
        "shutdown": execute_shutdown_command,
        "ai_chinese_mode": execute_ai_chinese_mode_command,
    }

    cmd = ""
    logging.info("Plugin started")

    while cmd != SHUTDOWN_COMMAND:
        response = None
        input_data = read_command()

        if input_data is None:
            continue

        if TOOL_CALLS_PROPERTY not in input_data:
            response = generate_failure_response("Malformed input")
            write_response(response)
            continue

        for tool_call in input_data[TOOL_CALLS_PROPERTY]:
            cmd = tool_call.get(FUNCTION_PROPERTY)

            if cmd not in commands:
                response = generate_failure_response(f"Unknown command: {cmd}")
                break

            if cmd in (INITIALIZE_COMMAND, SHUTDOWN_COMMAND):
                response = commands[cmd]()
            else:
                response = commands[cmd](
                    input_data.get(PARAMS_PROPERTY),
                    input_data.get(CONTEXT_PROPERTY),
                    input_data.get(SYSTEM_INFO_PROPERTY),
                )

        write_response(response)

    return 0

# =========================
# Pipe 通訊
# =========================
def read_command() -> dict | None:
    try:
        STD_INPUT_HANDLE = -10
        pipe = windll.kernel32.GetStdHandle(STD_INPUT_HANDLE)

        BUFFER_SIZE = 4096
        buffer = bytes(BUFFER_SIZE)
        bytes_read = wintypes.DWORD()

        success = windll.kernel32.ReadFile(
            pipe,
            buffer,
            BUFFER_SIZE,
            byref(bytes_read),
            None
        )

        if not success:
            return None

        raw = buffer.decode("utf-8")[:bytes_read.value]
        return json.loads(raw)

    except Exception as e:
        logging.error(f"read_command error: {e}")
        return None


def write_response(response: Response) -> None:
    try:
        STD_OUTPUT_HANDLE = -11
        pipe = windll.kernel32.GetStdHandle(STD_OUTPUT_HANDLE)

        payload = json.dumps(response).encode("utf-8")
        bytes_written = wintypes.DWORD()

        windll.kernel32.WriteFile(
            pipe,
            payload,
            len(payload),
            bytes_written,
            None
        )
    except Exception as e:
        logging.error(f"write_response error: {e}")

# =========================
# 回應工具
# =========================
def generate_success_response(message: str = None) -> Response:
    resp = {"success": True}
    if message:
        resp["message"] = message
    return resp


def generate_failure_response(message: str = None) -> Response:
    resp = {"success": False}
    if message:
        resp["message"] = message
    return resp

# =========================
# 內建功能
# =========================
def execute_initialize_command() -> dict:
    logging.info("Initialize executed")
    return generate_success_response("系統已成功初始化。")


def execute_shutdown_command() -> dict:
    logging.info("Shutdown executed")
    return generate_success_response("系統即將關閉。")

# =========================
# AI 中文控制層
# =========================
def execute_ai_chinese_mode_command(
    params: dict = None,
    context: dict = None,
    system_info: dict = None
) -> dict:

    if not params or "user_input" not in params:
        return generate_failure_response("未提供中文指令。")

    user_input = params["user_input"]

    logging.info(f"收到中文指令: {user_input}")

    # 1️⃣ 意圖判斷
    detected_command = None

    for keyword, mapped_command in COMMAND_MAP.items():
        if keyword in user_input:
            detected_command = mapped_command
            break

    # 2️⃣ 根據意圖串接其他功能
    if detected_command == "initialize":
        return execute_initialize_command()

    if detected_command == "shutdown":
        return execute_shutdown_command()

    if detected_command == "restart":
        return generate_success_response("已識別為重啟指令（尚未實作實際重啟功能）。")

    if detected_command == "status":
        return generate_success_response("系統目前運作正常。")

    if detected_command == "help":
        return generate_success_response(
            "可用中文指令：初始化、關閉、重啟、狀態、幫助。"
        )

    # 3️⃣ fallback
    return generate_success_response(
        f"已接收中文輸入：「{user_input}」，但未匹配到已知指令。"
    )


if __name__ == "__main__":
    main()
